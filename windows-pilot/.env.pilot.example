# Kore v0.5 Windows Server internal pilot environment example.
# Placeholder values only. Do not commit real secrets.

NODE_ENV=production
PORT=3002
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
REDIS_URL=redis://HOST:6379

# JWT_SECRET must be strong. Use a long random value.
JWT_SECRET=change-me-to-a-strong-secret

# Internal pilot only. Do not use mock for real production.
BILLING_PROVIDER=mock

ABACATEPAY_API_KEY=
ABACATEPAY_PRODUCT_ID=
ABACATEPAY_WEBHOOK_SECRET=

EVOLUTION_API_URL=
# Do not expose EVOLUTION_API_KEY to the frontend.
EVOLUTION_API_KEY=
WEBHOOK_URL=

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=pilot
SENTRY_RELEASE=v0.5.0
SENTRY_PROFILING_ENABLED=false
